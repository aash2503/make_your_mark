# ── AI Marking Assistant — Streamlit Secrets Template ──────────────────────
# Copy this file to .streamlit/secrets.toml and fill in your values.
# On Streamlit Cloud, paste these key=value pairs into the Secrets panel.

# Google Gemini API key (get from https://aistudio.google.com/app/apikey)
google_api_key = "YOUR_GEMINI_API_KEY_HERE"

# Gemini model to use (recommended: gemini-1.5-flash or gemini-1.5-pro)
gemini_model = "gemini-1.5-flash"

# Legacy PIN fallback (optional — leave blank to disable PIN login)
pin_code = ""
