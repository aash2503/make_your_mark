# ── AI Marking Assistant — Streamlit Secrets Template ──────────────────────
# Copy this file to .streamlit/secrets.toml and fill in your values.
# On Streamlit Cloud, paste these key=value pairs into the Secrets panel.

# Google Gemini API key (get from https://aistudio.google.com/app/apikey)
google_api_key = "YOUR_GEMINI_API_KEY_HERE"

# Gemini model to use (recommended: gemini-3.1-flash-lite)
gemini_model = "gemini-3.1-flash-lite"

# Google OAuth 2.0 credentials
# Create an OAuth client in Google Cloud Console and set the redirect URI to your app URL.
google_oauth_client_id = "YOUR_GOOGLE_OAUTH_CLIENT_ID"
google_oauth_client_secret = "YOUR_GOOGLE_OAUTH_CLIENT_SECRET"
google_oauth_redirect_uri = "http://localhost:8501"

# Legacy PIN fallback (optional — leave blank to disable PIN login)
pin_code = ""
